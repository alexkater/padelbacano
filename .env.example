# Database
DATABASE_URL=postgres://user:password@host:5432/dbname

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth client ID
AUTH_GOOGLE_ID=

# Google OAuth client secret
AUTH_GOOGLE_SECRET=

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@padelbacano.com

# SMTP email delivery (optional; emails are logged and notification_log records failure when absent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Notification provider selection (for deterministic E2E tests)
# EMAIL_PROVIDER=smtp|mock|log (default: smtp if SMTP_HOST set, log otherwise)
# WHATSAPP_PROVIDER=api|mock|log (default: api if WHATSAPP_TOKEN set, log otherwise)
# PUSH_PROVIDER=webpush|mock|log (default: webpush if VAPID keys set, log otherwise)
EMAIL_PROVIDER=
WHATSAPP_PROVIDER=
PUSH_PROVIDER=
